ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/apps/cuda/11.8/bin/nvcc

cflags = -pthread -B /nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/include -fPIC -O2 -isystem /nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/include -fPIC -I/nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/lib/python3.10/site-packages/torch/include -I/nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/lib/python3.10/site-packages/torch/include/TH -I/nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/lib/python3.10/site-packages/torch/include/THC -I/usr/local/apps/cuda/11.8/include -I/nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/include/python3.10 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=boundary_max_pooling_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -I/nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/lib/python3.10/site-packages/torch/include -I/nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/lib/python3.10/site-packages/torch/include/TH -I/nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/lib/python3.10/site-packages/torch/include/THC -I/usr/local/apps/cuda/11.8/include -I/nfs/hpc/share/wangtie/2021/miniconda3/envs/opentad/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' --expt-relaxed-constexpr -allow-unsupported-compiler -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=boundary_max_pooling_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_90,code=compute_90 -gencode=arch=compute_90,code=sm_90 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /nfs/hpc/dgx2-6/tmp/2024/5/10/OpenTAD/opentad/models/roi_heads/roi_extractors/boundary_pooling/build/temp.linux-x86_64-3.10/boundary_max_pooling_cuda.o: compile /nfs/hpc/dgx2-6/tmp/2024/5/10/OpenTAD/opentad/models/roi_heads/roi_extractors/boundary_pooling/boundary_max_pooling_cuda.cpp
